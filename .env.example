# =========================================================================
# Tuck Meet - environment configuration
# Copy this file to ".env" and fill in real values. NEVER commit ".env".
# =========================================================================

# Flask secret key used to sign sessions and tokens.
# Generate one with:  python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change-me-to-a-long-random-string

# Environment: "development" or "production"
FLASK_ENV=development

# Database (SQLite by default; point at Postgres in production if desired)
DATABASE_URL=sqlite:///tuckmeet.db

# Only addresses ending in this domain may register.
ALLOWED_EMAIL_DOMAIN=tuck.dartmouth.edu

# --- Email delivery ------------------------------------------------------
# EMAIL_BACKEND options:
#   stub  -> no real email is sent; messages are logged and written to ./outbox
#   smtp  -> send via an SMTP server using the settings below
EMAIL_BACKEND=stub
MAIL_FROM=tuckmeet@tuck.dartmouth.edu

# Only required when EMAIL_BACKEND=smtp
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_USE_TLS=true

# --- Matching ------------------------------------------------------------
# Days to avoid re-pairing the same two people.
REMATCH_COOLDOWN_DAYS=21

# Shared secret required to trigger the matching run over HTTP.
MATCHING_TRIGGER_TOKEN=change-me-too
